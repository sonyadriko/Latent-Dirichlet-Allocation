# Copy to .env and fill in your external MySQL connection details.

# --- MySQL (external server) ---
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=lda_user
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=lda_app

# Optional: provide a full SQLAlchemy URL instead of the MYSQL_* parts above.
# Must use the aiomysql driver and utf8mb4 charset.
# DATABASE_URL=mysql+aiomysql://lda_user:change-me@your-mysql-host:3306/lda_app?charset=utf8mb4

# --- App secrets ---
SECRET_KEY=lda-secret-key-2024
JWT_SECRET_KEY=jwt-secret-key-lda-2024
